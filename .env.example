APP_ENV=development
APP_NAME=helly
APP_LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
HELLY_PROCESS_TYPE=api

API_HOST=0.0.0.0
API_PORT=8000
# Railway injects PORT automatically for the public API service.
PORT=

WORKER_POLL_INTERVAL_SECONDS=5
SCHEDULER_POLL_INTERVAL_SECONDS=15

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL_EXTRACTION=gpt-5.4
OPENAI_MODEL_REASONING=gpt-5.4
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-mini-transcribe
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256

SUPABASE_URL=
SUPABASE_DB_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_PRIVATE=helly-private
DB_POOL_SIZE=2
DB_POOL_MAX_OVERFLOW=0
DB_POOL_TIMEOUT_SECONDS=30

QUEUE_BACKEND=database
REDIS_URL=

# Optional live-validation tooling for Railway logs
RAILWAY_API_TOKEN=
RAILWAY_ENVIRONMENT_ID=
