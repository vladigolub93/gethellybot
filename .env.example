APP_ENV=development
APP_NAME=helly
APP_LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
HELLY_PROCESS_TYPE=api

API_HOST=0.0.0.0
API_PORT=8000
# Railway injects PORT automatically for the public API service.
PORT=

WORKER_POLL_INTERVAL_SECONDS=5
SCHEDULER_POLL_INTERVAL_SECONDS=15

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL_EXTRACTION=gpt-4.1-mini
OPENAI_MODEL_REASONING=gpt-4.1

SUPABASE_URL=
SUPABASE_DB_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_PRIVATE=helly-private

QUEUE_BACKEND=database
REDIS_URL=
