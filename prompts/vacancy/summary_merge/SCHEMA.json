{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VacancySummaryMerge",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["draft"]
    },
    "role_title": {
      "type": ["string", "null"],
      "maxLength": 120
    },
    "seniority_normalized": {
      "type": ["string", "null"],
      "enum": ["junior", "middle", "senior", null]
    },
    "primary_tech_stack": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 12
    },
    "project_description_excerpt": {
      "type": ["string", "null"],
      "maxLength": 1200
    },
    "approval_summary_text": {
      "type": ["string", "null"],
      "maxLength": 600
    },
    "inconsistency_issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 12
    }
  },
  "required": [
    "status",
    "role_title",
    "seniority_normalized",
    "primary_tech_stack",
    "project_description_excerpt",
    "approval_summary_text",
    "inconsistency_issues"
  ]
}
