{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InterviewQuestionPlan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          },
          "type": {
            "type": "string",
            "enum": ["behavioral", "situational", "role_specific", "motivation"]
          },
          "question": {
            "type": "string",
            "maxLength": 260
          }
        },
        "required": ["id", "type", "question"]
      }
    },
    "fallback_used": {
      "type": "boolean"
    }
  },
  "required": ["questions", "fallback_used"]
}
